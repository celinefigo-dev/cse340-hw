<body>
    <main>
        <h1>Welcome to CSE Motors!</h1>
        <!--<%- messages() %> -->
        <section class="promo">
            <picture>
                <source media="(max-width: 601px)" srcset="/images/vehicles/delorean.jpg" />
                <source media="(min-width: 600px)" srcset="/images/vehicles/delorean-tn.jpg" />
                <img src="/public/images/vehicles/delorean.jpg" alt="DMC DeLorean" />
            </picture>

            <div class="features-container">
                <ul class="features">
                    <h2>DMC DeLorean</h2>
                    <li>3 Cup holders</li>
                    <li>Superman doors</li>
                    <li>Fuzzy dice!</li>
                </ul>
                <button>Own Today</button>
            </div>
        </section>


        <section class="container-rewiews-upgrades">

            <h2>DeLorean Upgrades</h2>
            <section class="upgrades">
                <div class="upgrade-grid">

                    <div class="upgrade-master">
                        <div class="upgrade">
                            <img src="/public/images/upgrades/flux-cap.png" alt="Flux Capacitor" />
                        </div>
                        <a href="">Flux Capacitor</a>
                    </div>

                    <div class="upgrade-master">
                        <div class="upgrade">
                            <img src="/public/images/upgrades/flame.jpg" alt="Flame Decals" />
                        </div>
                        <a href="">Flame Decals</a>
                    </div>
                    <div class="upgrade-master">
                        <div class="upgrade">
                            <img src="/public/images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers" />
                        </div>
                        <a href="">Bumper Stickers</a>
                    </div>
                    <div class="upgrade-master">
                        <div class="upgrade">
                            <img src="/public/images/upgrades/hub-cap.jpg" alt="Hub Caps" />
                        </div>
                        <a href="">Hub Caps</a>
                    </div>


                </div>
            </section>
            <h2>DMC DeLorean Reviews</h2>
            <section class="reviews">
                <ul>
                    <li>"So fast it's almost like traveling in time." (4/5)</li>
                    <li>"Coolest ride on the road." (4/5)</li>
                    <li>"I'm feeling McFly!" (5/5)</li>
                    <li>"The most futuristic ride of our day." (4.5/5)</li>
                    <li>"80's livin and I love it!" (5/5)</li>
                </ul>
            </section>


        </section>
    </main>
</body>